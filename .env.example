# Server-only OpenAI configuration. Never expose this key in app.js or index.html.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Create the administrator once, then remove ADMIN_BOOTSTRAP_PASSWORD from .env.
ADMIN_EMAIL=glory@alrassteel.com
ADMIN_BOOTSTRAP_PASSWORD=
APP_SESSION_SECRET=

# Supabase backend. Keep SUPABASE_SERVICE_ROLE_KEY server-side only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only lead discovery and enrichment keys.
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=

# Phase 5 external integrations. Keep private keys server-side only.
REACT_APP_GOOGLE_PLACES_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ZAWYA_API_KEY=
ZAWYA_API_URL=
ERP_API_BASE_URL=
ERP_API_KEY=
ENABLE_GOOGLE_PLACES=true
ENABLE_CLAUDE_ENRICHMENT=true
ENABLE_MARKET_INTEL=true
ENABLE_ERP_LOOKUP=true
ENABLE_LINKEDIN_SEARCH=true
